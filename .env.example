# =============================================================================
# Production Rescue Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# WARNING: Never commit your .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Required Configuration
# -----------------------------------------------------------------------------

# Ethereum RPC URL (Infura, Alchemy, or other providers)
# Example: https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private key of the wallet to rescue
# WARNING: This is highly sensitive! Use a dedicated wallet for rescue operations
# Example: abc123... (32 bytes without 0x)
PRIVATE_KEY=

# Target address to send rescued funds to (your safe wallet)
# Example: 0x1234567890123456789012345678901234567890
RESCUE_ADDRESS=

# Chain ID (1 = Ethereum Mainnet, 8453 = Base, 42161 = Arbitrum, etc.)
CHAIN_ID=1

# -----------------------------------------------------------------------------
# Flashbots Configuration
# -----------------------------------------------------------------------------

# Flashbots Relay URL (default: https://relay.flashbots.net)
FLASHBOTS_RELAY=https://relay.flashbots.net

# Auth signer for Flashbots (separate wallet for authentication)
# Get your auth signer at: https://docs.flashbots.net/flashbots-protect/quick-start
FLASHBOTS_AUTH_SIGNER=

# Additional relays (comma-separated)
# ULTRASOUND_RELAY=https://relay.ultrasound.money
# EDEN_RELAY=https://relay.edennetwork.io

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------

# Multiple RPC URLs for redundancy (comma-separated)
# RPC_URLS=https://mainnet.infura.io/v3/PROJECT1,https://eth-mainnet.g.alchemy.com/v2/PROJECT2

# -----------------------------------------------------------------------------
# Rescue Configuration
# -----------------------------------------------------------------------------

# ERC20 tokens to rescue (comma-separated addresses)
# TOKEN_ADDRESSES=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0x6B175474E89094C44Da98b954EedeAC495271d0F

# NFT contracts to rescue (comma-separated addresses)
# NFT_ADDRESSES=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D

# -----------------------------------------------------------------------------
# Gas Strategy
# -----------------------------------------------------------------------------

# Base gas multiplier (default: 2)
# GAS_BASE_MULTIPLIER=2

# Attack gas multiplier (default: 6 - aggressive)
# GAS_ATTACK_MULTIPLIER=6

# Maximum gas multiplier cap (default: 10)
# GAS_MAX_MULTIPLIER=10

# -----------------------------------------------------------------------------
# Bundle Configuration
# -----------------------------------------------------------------------------

# Target blocks ahead for bundle inclusion (default: 1)
# TARGET_BLOCKS_AHEAD=1

# Maximum retry blocks (default: 10)
# MAX_RETRY_BLOCKS=10

# Bundle timeout in ms (default: 25000)
# BUNDLE_TIMEOUT=25000

# Require simulation before send (default: true)
# REQUIRE_SIMULATION=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Enable timestamps (default: true)
# LOG_TIMESTAMPS=true
