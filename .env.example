# =============================================================================
# MEV Rescue Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Wallet Configuration
# -----------------------------------------------------------------------------
# Private key of the rescue wallet (without 0x prefix)
RESCUE_PRIVATE_KEY=your_private_key_here

# Destination address for rescued funds
RESCUE_DESTINATION=0x0000000000000000000000000000000000000000

# Monitored wallets (comma-separated, for rescue operations)
MONITORED_WALLETS=0x0000000000000000000000000000000000000001,0x0000000000000000000000000000000000000002

# -----------------------------------------------------------------------------
# Chain RPC Endpoints
# -----------------------------------------------------------------------------
# Ethereum Mainnet
ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/your-api-key
ETH_RPC_FALLBACK=https://eth.llamarpc.com

# Base
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/your-api-key
BASE_RPC_FALLBACK=https://base.llamarpc.com

# Polygon
POLYGON_RPC=https://polygon-rpc.com
POLYGON_RPC_FALLBACK=https://polygon.llamarpc.com

# BSC
BSC_RPC=https://bsc-dataseed.binance.org
BSC_RPC_FALLBACK=https://bsc.llamarpc.com

# -----------------------------------------------------------------------------
# Relay Configuration
# -----------------------------------------------------------------------------
# Flashbots
FLASHBOTS_SIGNING_KEY=your-flashbots-signing-key

# bloXroute
BLOXROUTE_AUTH_TOKEN=your-bloxroute-token
BLOXROUTE_ENDPOINT=https://api.bloxroute.com

# Eden Network
EDEN_API_KEY=your-eden-api-key

# -----------------------------------------------------------------------------
# Telegram Alerts
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Alert thresholds
ALERT_ON_ATTACK=true
ALERT_ON_RESCUE_SUCCESS=true
ALERT_ON_RESCUE_FAILURE=true

# -----------------------------------------------------------------------------
# Monitoring & Dashboard
# -----------------------------------------------------------------------------
# Prometheus metrics port
METRICS_PORT=3000

# Dashboard server port
DASHBOARD_PORT=3001

# Enable dashboard
ENABLE_DASHBOARD=true

# -----------------------------------------------------------------------------
# Bot Configuration
# -----------------------------------------------------------------------------
# Supported chains (comma-separated: ethereum,base,polygon,bsc)
ENABLED_CHAINS=ethereum,base,polygon,bsc

# Block confirmation wait
BLOCK_CONFIRMATIONS=1

# Mempool polling interval (ms)
MEMPOOL_POLL_INTERVAL=1000

# Max gas price multiplier (for priority)
GAS_MULTIPLIER=3

# Bundle retry attempts
MAX_RETRY_ATTEMPTS=3

# Retry delay (ms)
RETRY_DELAY=5000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_ETH_RESCUE=true
ENABLE_ERC20_RESCUE=true
ENABLE_NFT_RESCUE=true
ENABLE_APPROVAL_REVOCATION=false
ENABLE_PRIVATE_MEMPOOL=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true
