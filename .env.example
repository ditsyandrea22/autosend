# =============================================================================
# Ethereum Rescue Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# WARNING: Never commit your .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Required Configuration
# -----------------------------------------------------------------------------

# Ethereum RPC URL (Infura, Alchemy, or other providers)
# Example: https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private key of the wallet to rescue (without 0x prefix)
# WARNING: This is highly sensitive! Consider using a hardware wallet in production
# Example: abc123... (32 bytes without 0x)
PRIVATE_KEY=

# Target address to send rescued funds to
# Example: 0x1234567890123456789012345678901234567890
TO_ADDRESS=

# -----------------------------------------------------------------------------
# Optional: Multiple RPC URLs for redundancy (comma-separated)
# -----------------------------------------------------------------------------
# RPC_URLS=https://mainnet.infura.io/v3/PROJECT1,https://eth-mainnet.g.alchemy.com/v2/PROJECT2

# -----------------------------------------------------------------------------
# Token and NFT Addresses to Monitor (comma-separated)
# -----------------------------------------------------------------------------
# TOKEN_ADDRESSES=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0x6B175474E89094C44Da98b954EedeAC495271d0F
# NFT_ADDRESSES=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D

# -----------------------------------------------------------------------------
# Flashbots Configuration (REQUIRED for private transactions)
# -----------------------------------------------------------------------------
# Get your auth signer at: https://docs.flashbots.net/flashbots-protect/quick-start
# The auth signer is a separate wallet used for authentication with Flashbots relay
FLASHBOTS_AUTH_SIGNER=

# -----------------------------------------------------------------------------
# Builder Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of builders to use
# Available: flashbots, beaverbuild, bloxroute, builder0x69
# Note: Most builders require private API access
# BUILDERS=flashbots

# -----------------------------------------------------------------------------
# Strategy Configuration
# -----------------------------------------------------------------------------
# Block targeting strategy: fast, balanced, aggressive
# BLOCK_TARGET_STRATEGY=balanced

# Gas multiplier (how much to multiply base gas price by)
# Higher = more competitive but more expensive
# GAS_MULTIPLIER=6

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
# Latency target in milliseconds (for RPC performance monitoring)
# LATENCY_TARGET_MS=50

# Enable mempool monitoring (set to 'false' to disable)
# ENABLE_MEMPOOL_MONITORING=true

# -----------------------------------------------------------------------------
# Advanced: Custom Approval Monitoring
# -----------------------------------------------------------------------------
# JSON array of approvals to monitor
# Example: [{"token": "0x...", "spender": "0x..."}]
# APPROVALS_TO_MONITOR=[]
